# ── KAVACH v2 configuration ─────────────────────────────────────
# LLM policy (docs/06 §3): mock = default, no key needed.
# live requires BOTH a key and LLM_LIVE_ACK=yes. Never in tests/CI.
LLM_MODE=mock                # mock | replay | live
EMBED_MODE=                  # empty = follows LLM_MODE
GEMINI_API_KEY=
LLM_LIVE_ACK=no
LLM_DAILY_BUDGET_USD=2

# core services (docker-compose defaults)
DATABASE_URL=postgresql+psycopg://kavach:kavach@postgres:5432/kavach
REDIS_URL=redis://redis:6379/0

# security — CHANGE THESE for any non-local deployment
JWT_SECRET=dev-only-change-me
PII_MASTER_KEY=dev-only-32-bytes-change-me!!    # AES-256 master key material

CORS_ORIGINS=["http://localhost:3000"]
ENV=dev
